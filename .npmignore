# Exclude all top-level hidden directories (.git, .github, .vscode, .expo, .claude, ...)
/.*/

# Tarballs generated by `npm pack`
/*.tgz

# Source TypeScript (already compiled to build/)
/src/

# Source maps (build/ still ships the compiled .js and .d.ts)
*.map

# Tests & mocks
__mocks__/
__tests__/
/android/src/androidTest/
/android/src/test/

# Native build artifacts (rebuilt in the consumer's project)
/android/build/
/android/.gradle/
/android/.cxx/
/ios/build/
/ios/Pods/
/ios/*.xcworkspace
/ios/*.xcodeproj/xcuserdata/

# Example app
/example/

# Dev tooling & configs (not needed by consumers)
/internal/
/babel.config.js
/tsconfig.json
/eslint.config.cjs
/.prettierrc

# Logs
*.log
